<?xml version="1.0" ?>
<robot name="amr_car" xmlns:xacro="http://www.ros.org/wiki/xacro">
  <static>false</static>
    <link name="chassis">
    <pose>0 0 0 0 0 0</pose>

    <inertial>
      <mass value="1"/>
      <origin rpy="0 0 0", xyz="0 0 0">
      <inertia ixx="0" ixy="0" ixz="0" iyy="0" iyz="0" izz="0"/>
    </inertial>

    <collision name="collision_chassis">
      <geometry>
        <!-- <mesh>
          <uri>model://amr_car/meshes/chassis.stl</uri>
          <scale>0.01 0.01 0.01</scale>
        </mesh> -->
        <box size="2 2 1"/>
      </geometry>
    </collision>

    <visual name="visual_chassis">
      <geometry>
        <!-- <mesh>
          <uri>model://amr_car/meshes/chassis.stl</uri>
          <scale>0.01 0.01 0.01</scale>
        </mesh> -->
        <box size="2 2 1"/>
      </geometry>
      <!-- <material>
        <script>
          <uri>file://media/materials/scripts/gazebo.material</uri>
          <name>Gazebo/Blue</name>
        </script>
      </material> -->
    </visual>
  </link>
  
  
</robot>