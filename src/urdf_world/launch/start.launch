<?xml version="1.0" encoding="UTF-8"?>

<launch>
  <param name="robot_description" command="$(find xacro)/xacro --inorder '$(find_amr_car_description)/urdf/amr_car.urdf'" />
  <arg name="model" value="$(find find_amr_car_description)/urdf/amr_car.urdf" />
  <arg name="x" default="0"/>
  <arg name="y" default="0"/>
  <arg name="z" default="0"/>
  <node name="my_robot_spawn" pkg="gazebo_ros" type="spawn_model" output="screen"
        args="-urdf -param robot_description -model $(arg model) -x $(arg x) -y $(arg y) -z $(arg z)">
</launch>
